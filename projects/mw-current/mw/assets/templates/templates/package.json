{
  "name": "motiwiki-2022-app-templates",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./modules/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path ../dev/.gitignore",
