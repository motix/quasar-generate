{
  "name": "@motinet/quasar-generate",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "node scripts/bundle-prettier-plugin-sort-imports.js && yarn dlx @yarnpkg/sdks vscode && prettier --write ./.vscode/*.*",
    "lint": "eslint -c ./eslint.config.js \"./src/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "clean": "yarn format --log-level warn && yarn lint --fix",
    "build": "yarn tsc",
    "watch": "yarn tsc --watch",
    "create-ext": "node ./dist/create-ext.js",
    "create-ext-site": "node ./dist/create-ext-site.js",
    "create-ext-firebase": "node ./dist/create-ext-firebase.js",
    "create-all": "node ./dist/create-all.js"
  },
  "devDependencies": {
    "@dreamonkey/cli-ghostwriter": "^0.2.0",
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "^2.6.0",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@vue/compiler-sfc": "^3.5.32",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "firebase": "^12.12.0",
    "globals": "^17.5.0",
    "lodash-es": "^4.18.1",
    "prettier": "^3.8.3",
    "quasar": "^2.19.3",
    "typescript": "^5.9.3",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^5.0.4"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
