    "@types/node": "^25.9.1",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
